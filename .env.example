# copy to .env for plain-env dev, or set these in infisical instead
# (scripts/with-env.sh auto-detects infisical and falls back to this)

# last.fm api key for the now-playing widget — https://www.last.fm/api/account/create
LASTFM_API_KEY=

# encrypts the settings row stored in sqlite.
# generate one with: openssl rand -base64 32
# if omitted, the app creates DATA_DIR/settings.encryption.key automatically.
SETTINGS_ENCRYPTION_KEY=

# optional: bootstrap an account from the environment
ADMIN_USERNAME=
ADMIN_PASSWORD=
# optional: block public signups (accounts then only come from the env)
DISABLE_REGISTRATION=false

# set true only behind an https reverse proxy
COOKIE_SECURE=false
